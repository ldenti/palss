rule bcftools:
    input:
        fa=FA,
        bam=rules.minimap2.output.bam,
    output:
        vcf=pjoin(WD, "callsets", "bcftools-short.vcf.gz"),
    threads: workflow.cores
    conda:
        "./envs/bcftools.yml"
    shell:
        """
        bcftools mpileup -Ou -f {input.fa} {input.bam} | bcftools call -mv -Oz -o {output.vcf}
        """


