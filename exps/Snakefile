    output:
        directory(pjoin(WD, "{n}", "happy")),
    threads: workflow.cores
    conda:
        "./envs/happy.yml"
    shell:
        """
        bash ./scripts/run_happy.sh {input.fa} {input.bed} {output} {input.vcf1} {input.vcf2} {input.vcfs} {input.palss}
        """


