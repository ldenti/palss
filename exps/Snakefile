rule faidx:
    input:
        FA,
    output:
        FA + ".fai",
    conda:
        "./envs/samtools.yml"
    shell:
        """
        samtools faidx {input}
        """


rule dipcall:
    input:
        fa=FA,
        # bed=PARBED,
        hap1=pjoin(WD, sample + "-hap1.fa"),  # paternal?
        hap2=pjoin(WD, sample + "-hap2.fa"),  # maternal?
    output:
        vcf=pjoin(WD, "callsets", "dipcall", "prefix.dip.vcf.gz"),
        bed=pjoin(WD, "callsets", "dipcall", "prefix.dip.bed"),  # DIPBED
        bam1=pjoin(WD, "callsets", "dipcall", "prefix.hap1.bam"),
        bam2=pjoin(WD, "callsets", "dipcall", "prefix.hap2.bam"),
    params:
        wdir=pjoin(WD, "callsets", "dipcall"),
        prefix=pjoin(WD, "callsets", "dipcall", "prefix"),
        mak=pjoin(WD, "callsets", "dipcall.mak"),
    threads: workflow.cores
    conda:
        "./envs/dipcall.yml"
    shell:
        """
        run-dipcall -t {threads} {params.prefix} {input.fa} {input.hap1} {input.hap2} > {params.mak}
        mkdir -p {params.wdir}
        make -j 2 -f {params.mak}
        tabix -p vcf {output.vcf}
        samtools index {output.bam1}
        samtools index {output.bam2}
        """


rule clean_dipcall:
    input:
        fai=FA + ".fai",
        bed=pjoin(WD, "callsets", "dipcall", "prefix.dip.bed"),
        vcf=pjoin(WD, "callsets", "dipcall", "prefix.dip.vcf.gz"),
    output:
        vcf=pjoin(WD, "callsets", "dipcall.vcf.gz"),
        vcf1=pjoin(WD, "callsets", "dipcall-short.vcf.gz"),
        vcf2=pjoin(WD, "callsets", "dipcall-long.vcf.gz"),
        bed=pjoin(WD, "callsets", "dipcall.bed"),
    conda:
        "./envs/bcftools.yml"
    shell:
        """
        cp {input.bed} {output.bed}
        #
        bcftools reheader --fai {input.fai} {input.vcf} | bcftools norm -Oz --multiallelics - > {output.vcf}
        tabix -p vcf {output.vcf}
        #
        bcftools view -i '(ILEN > -50 && ILEN < 50)' -Oz {output.vcf} > {output.vcf1}
        tabix -p vcf {output.vcf1}
        #
        bcftools view -v indels -i '(ILEN <= -50 || ILEN >= 50)' -Oz {output.vcf} > {output.vcf2}
        tabix -p vcf {output.vcf2}
        """


rule minimap2:
    input:
        fa=FA,
        fq=rules.combine.output.fq,
    output:
        bam=pjoin(WD, sample + "-reads.bam"),
    threads: workflow.cores
    conda:
        "./envs/minimap2.yml"
    shell:
        """
        minimap2 -ax map-hifi --MD --eqx -Y -R '@RG\\tID:{sample}\\tSM:{sample}' -t{threads} {input.fa} {input.fq} | samtools view -bS | samtools sort -@ $(({threads}-1)) -T {output.bam} > {output.bam}
        samtools index {output.bam}
        """


rule sniffles:
    input:
        fa=FA,
        bam=rules.minimap2.output.bam,
        bed=TRF,
    output:
        vcf=pjoin(WD, "callsets", "sniffles-output.vcf"),
    conda:
        "./envs/sniffles.yml"
    threads: workflow.cores
    shell:
        """
        sniffles --threads {threads} --mapq 20 --minsupport auto --phase --minsvlen 50 --reference {input.fa} --input {input.bam} --vcf {output.vcf} --tandem-repeats {input.bed}
        """


rule sniffles_post:
    input:
        vcf=pjoin(WD, "callsets", "sniffles-output.vcf"),
    output:
        vcf=pjoin(WD, "callsets", "sniffles-long.vcf.gz"),
    conda:
        "./envs/bcftools.yml"
    shell:
        """
        # bgzip -c {input.vcf} > {output.vcf}
        bcftools view -Oz --include "INFO/SVTYPE='DEL' | INFO/SVTYPE='INS' | INFO/SVTYPE='DUP'" {input.vcf} > {output.vcf}
        # bcftools view --exclude "INFO/SVTYPE='BND'" {input.vcf} | python3 ./scripts/remove_strange_symbolic.py | bgzip -c > {output.vcf}
        tabix -p vcf {output.vcf}
        """


rule deepvariant:
    input:
        fa=FA,
        bam=rules.minimap2.output.bam,
    output:
        vcf=pjoin(WD, "callsets", "deepvariant-short.vcf.gz"),
    threads: workflow.cores
    conda:
        "./envs/deepvariant.yml"
    shell:
        """
        docker run --user $(id -u):$(id -g) -v /:/wd google/deepvariant:1.9.0 /opt/deepvariant/bin/run_deepvariant --model_type PACBIO --ref /wd/{input.fa} --reads /wd/{input.bam} --output_vcf /wd/{output.vcf} --num_shards {threads} --sample_name {sample}
        #
        # singularity run --bind /:/wd docker://google/deepvariant:1.9.0 /opt/deepvariant/bin/run_deepvariant --model_type PACBIO --ref /wd/{input.fa} --reads /wd/{input.bam} --output_vcf /wd/{output.vcf} --num_shards {threads} --sample_name {sample}
        #
        """


