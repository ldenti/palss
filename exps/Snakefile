### truvari


rule run_truvari:
    input:
        fa=FA,
        bed=rules.clean_dipcall.output.bed,
        vcf1=rules.get_vcfs.output.novel_vcf_long,
        vcf2=pjoin(WD, "callsets", "dipcall-long.vcf.gz"),
        vcfs=expand(
            pjoin(WD, "callsets", "{caller}-long.vcf.gz"),
            caller=["sniffles"],
        ),
        palss=expand(pjoin(WD, "callsets", "palss.w{w}.n{{n}}-long.vcf.gz"), w=Ws),
    output:
        directory(pjoin(WD, "{n}", "truvari")),
    threads: workflow.cores
    conda:
        "./envs/truvari.yml"
    shell:
        """
        bash ./scripts/run_truvari.sh {input.fa} {input.bed} {output} {threads} {input.vcf1} {input.vcf2} {input.vcfs} {input.palss}
        """
