rule run_happy:
    input:
        fa=FA,
        bed=rules.clean_dipcall.output.bed,
        vcf1=rules.get_vcfs.output.novel_vcf_short,
        vcf2=pjoin(WD, "callsets", "dipcall-short.vcf.gz"),
        vcfs=expand(
            pjoin(WD, "callsets", "{caller}-short.vcf.gz"),
